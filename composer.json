{
    "name": "myneid/laravel-db-tui",
    "description": "Interactive TUI database browser for Laravel — browse tables, sort columns, inspect rows, and run raw SQL",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "php-tui/php-tui": "^0.2",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "Myneid\\LaravelDbTui\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Myneid\\LaravelDbTui\\DatabaseTuiServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
